# onedesk Configuration
# Copy to .env and fill in your values

# --- App ---
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_PASSWORD=change-me
ADMIN_EMAIL=                          # Optional: pre-created admin email
FLASK_DEBUG=0
DATABASE_URL=sqlite:///onedesk.db
SESSION_COOKIE_SECURE=0               # Set to 1 when serving over HTTPS

# --- Company Info ---
COMPANY_NAME=My Company AB
COMPANY_ORG_NR=
COMPANY_ADDRESS=
COMPANY_EMAIL=
COMPANY_PHONE=
COMPANY_BANKGIRO=
COMPANY_BBAN=                         # Clearing+account digits for pain.001, e.g. 6501929223888
COMPANY_IBAN=                         # Optional IBAN (not used by HB pain.001)
COMPANY_BIC=HANDSESS                  # BIC of your bank (default: Handelsbanken)
COMPANY_VAT_NR=
COMPANY_LOGO_PATH=static/img/logo.png
COMPANY_REFERENCE=

# --- Fortnox ---
FORTNOX_CLIENT_ID=
FORTNOX_CLIENT_SECRET=
FORTNOX_REDIRECT_URI=http://localhost:5000/fortnox/callback
FORTNOX_INBOX_EMAIL=                  # Fortnox e-archive inbox address for PDF delivery
# Note: OAuth access token is stored in the database after the OAuth flow — not set here.

# --- Anthropic (for receipt OCR) ---
ANTHROPIC_API_KEY=
OLLAMA_MODEL=                         # e.g. llama3.2-vision (leave blank to use Anthropic)
OLLAMA_BASE_URL=http://localhost:11434/v1

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Invoice Settings ---
INVOICE_PAYMENT_DAYS=30
DEFAULT_HOURLY_RATE=1500
DEFAULT_CURRENCY=SEK
FY_START_MONTH=5                      # Fiscal year start month (5 = May)
